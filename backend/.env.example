# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URL=mongodb://localhost:27017/ai-psychologist

# JWT
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Chat / AI (Django or other API that handles conversation)
currentChatdjangoApi=http://localhost:8000/chat

# Email (for OTP and reset password)
# Choose one:
# MAIL_PROVIDER=smtp
# MAIL_PROVIDER=resend
MAIL_PROVIDER=resend

# Resend (recommended on Render)
# You can start with Resend's free `onboarding@resend.dev` sender.
RESEND_API_KEY=re_************************
MAIL_FROM="AI Psychologist <onboarding@resend.dev>"

# SMTP (fallback)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_CONNECTION_TIMEOUT_MS=12000
MAIL_GREETING_TIMEOUT_MS=12000
MAIL_SOCKET_TIMEOUT_MS=20000
USER_EMAIL=your-email@gmail.com
USER_PASS=your-app-password
